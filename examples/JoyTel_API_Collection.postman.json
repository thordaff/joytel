{
  "info": {
    "name": "JoyTel API Integration",
    "description": "Collection for testing JoyTel API integration endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Orders",
      "item": [
        {
          "name": "Submit eSIM Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_code\": \"ESIM_GLOBAL_1GB\",\n  \"quantity\": 1,\n  \"receive_name\": \"John Doe\",\n  \"phone\": \"+1234567890\",\n  \"email\": \"john@example.com\",\n  \"cid\": \"CUSTOMER_123\",\n  \"system_type\": \"warehouse\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            },
            "description": "Submit a new eSIM order to the warehouse system"
          }
        },
        {
          "name": "Query Order by TID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/orders/query?order_tid=JT20240223123456ABCDEF",
              "host": ["{{base_url}}"],
              "path": ["orders", "query"],
              "query": [
                {
                  "key": "order_tid",
                  "value": "JT20240223123456ABCDEF"
                }
              ]
            },
            "description": "Query order status by order TID"
          }
        },
        {
          "name": "Query Order by Code",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/orders/query?order_code=JT_ORDER_123",
              "host": ["{{base_url}}"],
              "path": ["orders", "query"],
              "query": [
                {
                  "key": "order_code",
                  "value": "JT_ORDER_123"
                }
              ]
            },
            "description": "Query order status by order code"
          }
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/orders?per_page=10&status=completed&system_type=warehouse",
              "host": ["{{base_url}}"],
              "path": ["orders"],
              "query": [
                {
                  "key": "per_page",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "completed"
                },
                {
                  "key": "system_type",
                  "value": "warehouse"
                }
              ]
            },
            "description": "List orders with pagination and filters"
          }
        },
        {
          "name": "Submit OTA Recharge",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_code\": \"RECHARGE_5GB\",\n  \"sn_pin\": \"1234567890123456\",\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/orders/ota-recharge",
              "host": ["{{base_url}}"],
              "path": ["orders", "ota-recharge"]
            },
            "description": "Submit OTA recharge order"
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "SN/PIN Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_tid\": \"JT20240223123456ABCDEF\",\n  \"sn_pin\": \"1234567890123456\",\n  \"order_code\": \"JT_ORDER_123\",\n  \"status\": \"success\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhook/sn-pin",
              "host": ["{{base_url}}"],
              "path": ["webhook", "sn-pin"]
            },
            "description": "Simulate SN/PIN callback from warehouse system"
          }
        },
        {
          "name": "QR Code Webhook", 
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_tid\": \"JT20240223123456ABCDEF\",\n  \"qrcode\": \"LPA:1$esim.example.com$12345-67890-ABCDEF\",\n  \"status\": \"completed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhook/qr-code",
              "host": ["{{base_url}}"],
              "path": ["webhook", "qr-code"]
            },
            "description": "Simulate QR code callback"
          }
        },
        {
          "name": "Coupon Redeem Notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "AppId",
                "value": "YOUR_APP_ID"
              },
              {
                "key": "TransId", 
                "value": "RSP_20240223123456_ABCDEF12"
              },
              {
                "key": "Timestamp",
                "value": "1708689296"
              },
              {
                "key": "Ciphertext",
                "value": "calculated_md5_hash"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"couponCode\": \"1234567890123456\",\n  \"status\": \"success\",\n  \"qrcode\": \"LPA:1$esim.example.com$12345\",\n  \"iccid\": \"1234567890123456789\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhook/notify/coupon/redeem",
              "host": ["{{base_url}}"],
              "path": ["webhook", "notify", "coupon", "redeem"]
            },
            "description": "Simulate coupon redeem notification from RSP system"
          }
        },  
        {
          "name": "eSIM Progress Notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "AppId",
                "value": "YOUR_APP_ID"
              },
              {
                "key": "TransId",
                "value": "RSP_20240223123456_ABCDEF13"
              },
              {
                "key": "Timestamp",
                "value": "1708689296"
              },
              {
                "key": "Ciphertext",
                "value": "calculated_md5_hash"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"iccid\": \"1234567890123456789\",\n  \"status\": \"installed\",\n  \"event\": \"installation_completed\",\n  \"deviceInfo\": {\n    \"imei\": \"123456789012345\",\n    \"model\": \"iPhone 15 Pro\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhook/notify/esim/esim-progress",
              "host": ["{{base_url}}"],
              "path": ["webhook", "notify", "esim", "esim-progress"]
            },
            "description": "Simulate eSIM progress notification from RSP system"
          }
        }
      ]
    },
    {
      "name": "Utilities",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/utils/health",
              "host": ["{{base_url}}"],
              "path": ["utils", "health"]
            },
            "description": "Check if the API service is running"
          }
        },
        {
          "name": "Configuration Check",
          "request": {
            "method": "GET", 
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/utils/config",
              "host": ["{{base_url}}"],
              "path": ["utils", "config"]  
            },
            "description": "Check API configuration status"
          }
        }
      ]
    }
  ]
}